# Dependencies
node_modules/
.npm-cache/

# Build output
dist/

# Python
__pycache__/
*.pyc
.venv/

# ── Personal data (never publish) ───────────────────
# Memory, notes, reflections, session dumps
memory/*
!memory/.gitkeep

# Group chat data, conversation logs, container logs
groups/*
!groups/.gitkeep

# SQLite databases, application state
store/*
!store/.gitkeep

# Runtime data, agent sessions, IPC
data/*
!data/.gitkeep

# Structured logs
logs/*
!logs/.gitkeep

# Work queue items and plans
queue/*
!queue/.gitkeep

# Backlog items
backlog/*
!backlog/.gitkeep

# Generated crontab (job definitions in cron/jobs/ are fine)
cron/crontab.generated

# ── Secrets ─────────────────────────────────────────
.env
*.keys.json
credentials-prime.json

# ── Config that's personal ──────────────────────────
# These YAML configs contain personal schedules, accounts, paths
# See config-examples/ for templates
nightctl.yaml
cronctl.yaml
memctl.yaml
logctl.yaml
briefings.yaml
reportctl.yaml
todoctl.yaml
agentctl.yaml

# ── Fleet (contains bot tokens, user data) ──────────
gateway/halfleet/

# ── Temp / OS / IDE ────────────────────────────────
.tmp-*
.DS_Store
.idea/
.vscode/
.nanoclaw/
.mcp.json
agents-sdk-docs
