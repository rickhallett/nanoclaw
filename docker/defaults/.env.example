# Halo container environment — copy to .env and fill in values.
# In K8s, these come from a Secret mounted at $HERMES_HOME/.env

# === Required ===
BOT_TOKEN=
ANTHROPIC_API_KEY=

# === Telegram ===
TELEGRAM_ALLOWED_USERS=

# === Model (override in config.yaml preferred) ===
# DEFAULT_MODEL=claude-sonnet-4-20250514
# DEFAULT_PROVIDER=anthropic

# === Cost control ===
# COST_CEILING_USD=50

# === Backup (K8s only) ===
# BACKUP_S3_BUCKET=
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
