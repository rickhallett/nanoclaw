+def _publish_halo_event(event_type: str, payload: dict, source: str) -> None:
+    """Publish a standardized event to Halostream. Non-fatal on failure."""
+    nats_pass = os.getenv("NATS_PASS", "")
+    if not nats_pass:
+        return
+
+    nats_url = os.getenv("NATS_URL", "nats://nats.halo-fleet.svc.cluster.local:4222")
+    nats_user = os.getenv("NATS_USER", "advisor")
+    event = {
+        "id": f"evt_{uuid.uuid4().hex}",
+        "type": event_type,
+        "version": 1,
+        "source": source,
+        "timestamp": datetime.now(timezone.utc).isoformat(),
+        "correlation_id": payload.get("correlation_id") or f"cor_{uuid.uuid4().hex}",
+        "payload": payload,
+    }
+    subject = f"halo.{event_type}"
+
+    async def _pub():
+        import nats
+        nc = await nats.connect(nats_url, user=nats_user, password=nats_pass)
+        try:
+            js = nc.jetstream()
+            await js.publish(
+                subject,
+                json.dumps(event).encode(),
+                headers={"Nats-Msg-Id": event["id"]},
+            )
+        finally:
+            await nc.close()
+
+    try:
+        asyncio.run(_pub())
+    except RuntimeError:
+        with concurrent.futures.ThreadPoolExecutor(max_workers=1) as pool:
+            pool.submit(asyncio.run, _pub()).result(timeout=30)
+    except Exception as e:
+        logger.error("Failed to publish NATS event %s: %s", event_type, e)
 
 
